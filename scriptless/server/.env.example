# Required: PostgreSQL connection string
DATABASE_URL=postgresql://scriptless:scriptless_dev@localhost:5432/scriptless?schema=public

# Required: JWT secret (min 32 chars, use a strong random string in production)
JWT_SECRET=change-this-to-a-64-character-random-string-in-production-abc123

# Required: Gemini API Key (get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Redis (for future job queue features)
REDIS_URL=redis://localhost:6379

# Optional: Email via SMTP (e.g. Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Optional: SMS via Twilio (https://twilio.com)
TWILIO_SID=ACxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_FROM=+1234567890

PORT=3001
NODE_ENV=development